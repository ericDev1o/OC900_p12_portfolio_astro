---
type Level = 3 | 4 | 5;

const { 
    level, 
    id } 
= Astro.props as {
    level: Level,
    id?: string
};

const Tag = `h${level}` as keyof HTMLElementTagNameMap;

const baseClass = 'leading-loose';

const styles = {
    3: 
        `pt-22 
        pb-6 
        text-3xl`,
    4: 
        `pt-12 
        pb-2 
        text-2xl`,
    5:
        `pb-4 
        text-xl`
}
---

<Tag
    class={`${baseClass} ${styles[level]}`}
    id={ id }
>
    <slot />
</Tag>