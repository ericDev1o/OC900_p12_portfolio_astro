---
type Level = 3 | 4 | 5;

const { 
    level, 
    id } 
= Astro.props as {
    level: Level,
    id?: string
};

const Tag = `h${level}` as keyof HTMLElementTagNameMap;

const baseClass = `
    max-w-[40ch] 
    leading-loose`;

const styles = {
    3: 'text-3xl',
    4: 'text-2xl',
    5: 'text-xl'
}
---

<Tag
    class={`${baseClass} ${styles[level]}`}
    id={ id }
>
    <slot />
</Tag>