---
const { 
    logoURI, 
    altText, 
    width, 
    height
} = Astro.props as {
    logoURI: string | undefined, 
    altText: string,
    width: number, 
    height: number
};
---
<img 
    src={logoURI} 
    width={width} 
    height={height} 
    class='
        p-6 
        w-auto 
        object-contain 
        transition-shadow 
        duration-600 
        ease-in-out 
        hover:shadow-[0_0_2em_rgba(100,108,255,0.6)] 
        motion-reduce:transition-none' 
    alt={altText}
    loading='lazy'
/>