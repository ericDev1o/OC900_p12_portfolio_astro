---
import IconLink from "./IconLink.astro";

interface Props {
  href: string;
  src?: string;
  altText: string;
  classNameImageWidthHeight: string
}

const { href, src, altText, classNameImageWidthHeight } = Astro.props as Props;
---

<IconLink 
    href={ href }
    src={ src } 
    alt={ altText }
    classNameA='p-6' 
    classNameImgWidthHeight={ classNameImageWidthHeight }
/>
