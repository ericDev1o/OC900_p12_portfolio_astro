---
import IconLink from '../UI/IconLink.astro';

import { logosMap } from '@/config/logoPathsConfig';

import { Image } from 'astro:assets';
---
    
<ul 
    class='
        flex 
        flex-col
        items-center 
        sm:flex-row
        gap-8'
>
    <li>
        <Image 
            src={logosMap.E} 
            class='
                cursor-not-allowed
                opacity-50 
                object-contain' 
            alt='Eric logo'
            width={15}
            height={24}
            sizes='15px'
            densities={[1, 1.5]}
            loading='eager'
            fetchpriority='high'
        />
    </li>
    <li>   
        <IconLink 
            href='https://github.com/ericDev1o' 
            src={logosMap.gitHub} 
            alt='GitHub logo'
            classNameImgWidthHeight='w-[25px] h-[24px]'
            sizes='25px'
        />
    </li>
    <li>   
        <IconLink 
            href='https://linkedin.com/in/ericfaraut' 
            src={logosMap.linkedIn} 
            alt='LinkedIn logo' 
            classNameImgWidthHeight='w-[29px] h-[24px]'
            sizes='29px'
        />
    </li>
</ul>