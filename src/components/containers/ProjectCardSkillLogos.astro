---
import { logos as logosMap, type  LogoKey } from '@/config/logoPathsConfig';

const { 
    logos: projectLogos, 
    repo 
} = Astro.props as {
  logos: LogoKey[];
  repo?: string;
}
---

{projectLogos.length > 0 && ( 
    <div 
        class='
            flex 
            flex-wrap 
            shrink-0 
            justify-between 
            items-center
            gap-3'
    >
        {projectLogos.map((logo) => {
            const src = logosMap[logo];
            if( ! src) return null;

            return (
            <a
                href={repo}
                target="_blank"
                rel='
                    noopener 
                    noreferrer'
                class='
                    hover:scale-110 
                    transition-transform 
                    motion-reduce:transform-none 
                    focus-visible:ring-4 
                    focus-visible:ring-blue-300 
                    focus-visible:ring-offset-2'
            >
                <img
                    src={src}
                    alt={logo}
                    width="32"
                    height="32"
                    loading="lazy"
                    decoding="async"
                />
            </a>
            );
        })}      
    </div>
)}