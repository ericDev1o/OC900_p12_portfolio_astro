---
import { 
    logosRaw as logosMap, 
    type  LogoKey 
} from '@/config/logoPathsConfig';

const {
    keys,
    repo
}= Astro.props as {
    keys: LogoKey[],
    repo?: string
};

const validKeys = keys
  .map((key) => {
    const src = logosMap[key];
    if (!src) return null;

    return { key, src };
  })
  .filter(Boolean) as { key: LogoKey; src: string }[]; 
---

 <div 
    class='
        flex 
        flex-wrap 
        shrink-0 
        justify-between 
        items-center
        gap-3'
>
    {
        validKeys.length === 0 
        ? null
        : validKeys.map(({key, src}) => {
            const image = (
                <img
                    src={src}
                    alt={`${key} logo`}
                    class='
                        h-8 
                        w-auto 
                        object-contain'
                    loading='lazy'
                    decoding='async'
                />
            );
            
            return repo 
            ? (
                <a
                    href={repo}
                    target='_blank'
                    rel={`
                        noopener 
                        noreferrer
                    `}
                    aria-label={`${key} (ouvre dans un nouvel onglet)`}
                    class={`
                    inline-block 
                    hover:scale-110 
                    transition-transform 
                    motion-reduce:transform-none 
                    focus-visible:ring-4 
                    focus-visible:ring-blue-300 
                    focus-visible:ring-offset-2
                    focus-visible:ring-offset-gray-900
                    `}
                >
                    {image}
                </a>
            )
            : image
        })
    }
 </div>