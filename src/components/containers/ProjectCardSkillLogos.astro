---
import { Image } from 'astro:assets';

import { 
    logosMap, 
    type  LogoKey 
} from '@/config/logoPathsConfig';

const {
    keys,
    repo
}= Astro.props as {
    keys: LogoKey[],
    repo?: string
};

const validKeys = keys
  .map((key) => {
    const src = logosMap[key];
    if (!src) return null;

    return { key, src };
  })
  .filter(Boolean) as { key: LogoKey; src: ImageMetadata }[]; 
---

 <div 
    class='
        flex 
        flex-wrap 
        shrink-0 
        justify-between 
        items-center
        gap-3'
>
    {
        validKeys.length === 0 
        ? null
        : validKeys.map(({key, src}) => {
            const image = (
                <Image
                    src={src}
                    alt={`${key} logo`}
                    class='
                        h-12 md:h-14 
                        w-auto 
                        object-contain'
                    loading='lazy'
                />
            );
            
            return repo 
            ? (
                <a
                    href={repo}
                    target='_blank'
                    rel={`
                        noopener 
                        noreferrer
                    `}
                    aria-label={`${key} (ouvre dans un nouvel onglet)`}
                    class={`
                        inline-block 
                        hover:scale-110 
                        transition-transform 
                        motion-reduce:transform-none 
                        focus-visible:ring-4 
                        focus-visible:ring-blue-300 
                        focus-visible:ring-offset-2
                        focus-visible:ring-offset-gray-900
                    `}
                >
                    {image}
                </a>
            )
            : image
        })
    }
 </div>